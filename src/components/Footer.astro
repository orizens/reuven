---
import { Icon } from "astro-icon/components";
import { navLinks } from "../data/nav";
import { site } from "../data/site";
---

<footer class="bg-gray-900 text-gray-400 py-10 px-4">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <h4
        class="text-white font-heading font-bold text-lg mb-2 flex items-center gap-2"
      >
        <Icon name="ph:house-bold" class="w-5 h-5 shrink-0" />
        {site.name}
      </h4>
      <p class="text-sm">
        Need help today? Call or text now for fast service from our garage door
        repair specialists serving all of {site.serviceRegion}.
      </p>
    </div>
    <div>
      <h4 class="text-white font-heading font-semibold mb-2">Quick Links</h4>
      <ul class="space-y-1 text-sm">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <h4 class="text-white font-heading font-semibold mb-2">Contact</h4>
      <p class="text-sm mb-1 flex items-center gap-2">
        <Icon name="ph:phone-call-bold" class="w-4 h-4 shrink-0" />
        <a href={site.phone.href} class="hover:text-white transition-colors"
          >{site.phone.display}</a
        >
      </p>
      <p class="text-sm flex items-center gap-2">
        <Icon name="ph:map-pin-bold" class="w-4 h-4 shrink-0" />
        Serving in {site.serviceRegion}
      </p>
      <p class="text-sm mt-1">{site.hoursShort}</p>
    </div>
  </div>
  <div
    class="max-w-6xl mx-auto mt-8 pt-6 border-t border-gray-800 text-center text-sm"
  >
    <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
  </div>
</footer>

<!-- WhatsApp Floating Button -->
<a
  href="https://wa.me/19549142217"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat with us on WhatsApp"
  class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 bg-green-500 hover:bg-green-600 text-white rounded-full shadow-lg transition-colors"
>
  <Icon name="ph:whatsapp-logo-fill" class="w-7 h-7" />
</a>
