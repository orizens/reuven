---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { site } from "../data/site";
import { services } from "../data/services";
import { features } from "../data/features";
import { testimonials } from "../data/testimonials";
import { serviceAreas } from "../data/serviceAreas";
---

<Layout
  title="Florida Garage Pros – Fast & Reliable Garage Door Repair in Florida"
  description="Florida Garage Pros offers fast, reliable garage door repair, spring replacement, opener repair, and new installations across Florida. Same-day service available. Call now!"
  activePage="home"
>
  <!-- Hero Section -->
  <section
    class="bg-gradient-to-br from-brand-blue to-brand-blue-dark text-white py-20 px-4"
  >
    <div class="max-w-4xl mx-auto text-center">
      <h1
        class="font-heading text-4xl md:text-5xl font-extrabold leading-tight mb-4"
      >
        Reliable Garage Door Repair in Florida
      </h1>
      <p class="text-xl md:text-2xl text-blue-200 mb-8 max-w-2xl mx-auto">
        Licensed &amp; insured technician ready to fix your garage door today.
        Service available across all major Florida cities.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={site.phone.href}
          class="bg-brand-orange hover:bg-brand-orange-dark text-white font-bold px-8 py-4 rounded-xl text-lg transition-colors shadow-lg flex items-center justify-center gap-2"
        >
          <Icon name="ph:phone-call-bold" class="w-5 h-5 shrink-0" />
          Call Now – {site.phone.display}
        </a>
        <a
          href="/contact"
          class="bg-white text-brand-blue hover:bg-blue-50 font-bold px-8 py-4 rounded-xl text-lg transition-colors shadow-lg"
        >
          Get a Free Quote
        </a>
      </div>
      <p class="mt-6 text-blue-300 text-sm">
        Available 7 days a week · No hidden fees · Fast response
      </p>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-16 px-4 bg-gray-50" id="services">
    <div class="max-w-6xl mx-auto">
      <h2
        class="font-heading text-3xl font-bold text-center text-brand-blue mb-2"
      >
        Our Services
      </h2>
      <p class="text-center text-gray-500 mb-12">
        Everything your garage door needs — handled by pros.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          services.slice(0, 4).map((service) => (
            <div class="bg-white rounded-2xl shadow p-6 text-center hover:shadow-lg transition-shadow">
              <div class="flex justify-center mb-3">
                <Icon name={service.icon} class="w-10 h-10 text-brand-blue" />
              </div>
              <h3 class="font-heading font-bold text-lg text-brand-blue mb-2">
                {service.title}
              </h3>
              <p class="text-gray-600 text-sm">
                {service.description.split(".")[0]}.
              </p>
            </div>
          ))
        }
      </div>
      <div class="text-center mt-10">
        <a
          href="/services"
          class="inline-block bg-brand-blue hover:bg-brand-blue-dark text-white font-bold px-8 py-3 rounded-xl transition-colors shadow"
        >
          View All Services →
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 px-4 bg-white" id="why-us">
    <div class="max-w-6xl mx-auto">
      <h2
        class="font-heading text-3xl font-bold text-center text-brand-blue mb-2"
      >
        Why Choose Florida Garage Pros?
      </h2>
      <p class="text-center text-gray-500 mb-12">
        Florida homeowners trust us for a reason.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          features.map((feature) => (
            <div class="flex items-start gap-4">
              <div class="shrink-0 mt-0.5">
                <Icon name={feature.icon} class="w-7 h-7 text-brand-orange" />
              </div>
              <div>
                <h3 class="font-heading font-bold text-gray-900 mb-1">
                  {feature.title}
                </h3>
                <p class="text-gray-600 text-sm">{feature.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 px-4 bg-blue-50" id="testimonials">
    <div class="max-w-6xl mx-auto">
      <h2
        class="font-heading text-3xl font-bold text-center text-brand-blue mb-2"
      >
        What Our Customers Say
      </h2>
      <p class="text-center text-gray-500 mb-12">
        Real reviews from real Florida homeowners.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          testimonials.map((t) => (
            <article class="bg-white rounded-2xl shadow p-6">
              <div class="flex gap-0.5 mb-2">
                {[...Array(5)].map(() => (
                  <Icon name="ph:star-fill" class="w-4 h-4 text-brand-orange" />
                ))}
              </div>
              <p class="text-gray-700 text-sm mb-4">"{t.quote}"</p>
              <footer class="text-sm font-semibold text-gray-900">
                — {t.name},{" "}
                <span class="text-gray-500 font-normal">{t.city}</span>
              </footer>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 px-4 bg-white" id="service-area">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-heading text-3xl font-bold text-brand-blue mb-2">
        Serving All of Florida
      </h2>
      <p class="text-gray-500 mb-8">
        We serve homeowners and businesses across the Sunshine State.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {
          serviceAreas.map((city) => (
            <span class="bg-blue-100 text-brand-blue font-medium px-4 py-2 rounded-full text-sm">
              {city}
            </span>
          ))
        }
        <span
          class="bg-blue-100 text-brand-blue font-medium px-4 py-2 rounded-full text-sm"
          >And more...</span
        >
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 px-4 bg-brand-blue text-white" id="contact">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading text-3xl font-bold text-center mb-2">
        Contact Us Today
      </h2>
      <p class="text-center text-blue-200 mb-10">
        Fill out the form below or call us directly — we respond fast.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
        <div>
          <h3 class="font-heading font-bold text-xl mb-4">Call or Text Us</h3>
          <a
            href={site.phone.href}
            class="flex items-center gap-3 text-2xl font-bold text-brand-orange hover:text-orange-300 transition-colors mb-6"
          >
            <Icon name="ph:phone-call-bold" class="w-7 h-7 shrink-0" />
            {site.phone.display}
          </a>
          <ul class="space-y-2 text-blue-200 text-sm">
            {
              [
                "Available 7 days a week",
                "Same-day appointments",
                "Free estimates",
                "Emergency service available",
              ].map((item) => (
                <li class="flex items-center gap-2">
                  <Icon
                    name="ph:check-circle-bold"
                    class="w-4 h-4 text-brand-orange shrink-0"
                  />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-4"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>
          <div>
            <label
              for="name"
              class="block text-sm font-medium text-blue-200 mb-1"
              >Your Name</label
            >
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="John Smith"
              class="w-full px-4 py-3 rounded-lg bg-blue-900 border border-blue-700 text-white placeholder-blue-400 focus:outline-none focus:ring-2 focus:ring-brand-orange"
            />
          </div>
          <div>
            <label
              for="phone"
              class="block text-sm font-medium text-blue-200 mb-1"
              >Phone Number</label
            >
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              placeholder="(555) 000-0000"
              class="w-full px-4 py-3 rounded-lg bg-blue-900 border border-blue-700 text-white placeholder-blue-400 focus:outline-none focus:ring-2 focus:ring-brand-orange"
            />
          </div>
          <div>
            <label
              for="message"
              class="block text-sm font-medium text-blue-200 mb-1"
              >How can we help?</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              placeholder="Describe the issue with your garage door..."
              class="w-full px-4 py-3 rounded-lg bg-blue-900 border border-blue-700 text-white placeholder-blue-400 focus:outline-none focus:ring-2 focus:ring-brand-orange"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-brand-orange hover:bg-brand-orange-dark text-white font-bold py-3 rounded-lg text-lg transition-colors shadow"
          >
            Send Message →
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
