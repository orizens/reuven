---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { contactItems, trustItems } from "../data/contact";
import { site } from "../data/site";
---

<Layout
  title="Contact Us – May Garage Doors LLC | Garage Door Repair in Florida"
  description={`Contact May Garage Doors LLC for fast garage door repair, spring replacement, or new installation. Call ${site.phone.display} or fill out our quick contact form.`}
  activePage="contact"
>
  <!-- Page Hero -->
  <section
    class="bg-gradient-to-br from-brand-blue to-brand-blue-dark text-white py-16 px-4 text-center"
  >
    <h1 class="font-heading text-4xl font-extrabold mb-3">Contact Us</h1>
    <p class="text-xl text-blue-200 max-w-xl mx-auto">
      Call, text, or send us a message — we respond quickly and are ready to
      help.
    </p>
  </section>

  <!-- Contact Content -->
  <main class="py-16 px-4">
    <div
      class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-start"
    >
      <!-- Contact Info -->
      <div>
        <h2 class="font-heading text-2xl font-bold text-brand-blue mb-6">
          Get In Touch
        </h2>
        <div class="space-y-6">
          {
            contactItems.map((item) => (
              <div class="flex items-start gap-4">
                <div class="bg-blue-100 text-brand-blue rounded-full p-3 shrink-0">
                  <Icon name={item.icon} class="w-5 h-5" />
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-1">{item.title}</h3>
                  {item.linkHref && item.title === "Phone / Text" ? (
                    <>
                      <a
                        href={item.linkHref}
                        class="text-2xl font-bold text-brand-orange hover:text-orange-600 transition-colors"
                      >
                        {item.detail}
                      </a>
                      {item.subDetail && (
                        <p class="text-gray-500 text-sm mt-1">
                          {item.subDetail}
                        </p>
                      )}
                    </>
                  ) : (
                    <>
                      <p class="text-gray-600 text-sm">{item.detail}</p>
                      {item.linkHref && item.linkLabel && (
                        <a
                          href={item.linkHref}
                          class="inline-flex items-center gap-1 mt-2 text-sm font-bold text-brand-blue hover:underline"
                        >
                          <Icon
                            name="ph:phone-call-bold"
                            class="w-3.5 h-3.5 shrink-0"
                          />
                          {item.linkLabel}
                        </a>
                      )}
                    </>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </main>

  <!-- Trust Strip -->
  <section class="bg-blue-50 py-10 px-4">
    <div
      class="max-w-4xl mx-auto flex flex-wrap justify-center gap-6 text-center"
    >
      {
        trustItems.map((item) => (
          <div class="flex flex-col items-center gap-1">
            <Icon name={item.icon} class="w-6 h-6 text-brand-blue" />
            <span class="text-sm font-semibold text-gray-700">
              {item.label}
            </span>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
