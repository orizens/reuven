---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { services } from "../data/services";
import { site } from "../data/site";
---

<Layout
  title="Services – Florida Garage Pros | Garage Door Repair in Florida"
  description="Explore all garage door services offered by Florida Garage Pros — repair, spring replacement, opener repair, new installations, and emergency service across Florida."
  activePage="services"
>
  <!-- Page Hero -->
  <section
    class="bg-gradient-to-br from-brand-blue to-brand-blue-dark text-white py-16 px-4 text-center"
  >
    <h1 class="font-heading text-4xl font-extrabold mb-3">
      Our Garage Door Services
    </h1>
    <p class="text-xl text-blue-200 max-w-xl mx-auto">
      Professional, fast, and affordable solutions for every garage door problem
      in Florida.
    </p>
  </section>

  <!-- Services List -->
  <main class="py-16 px-4">
    <div class="max-w-5xl mx-auto space-y-12">
      {
        services.map((service, i) => (
          <article
            class={`flex flex-col md:flex-row items-start gap-6 rounded-2xl shadow-sm p-8 hover:shadow-md transition-shadow border ${i === services.length - 1 ? "bg-blue-50 border-brand-blue" : "bg-white border-gray-200"}`}
          >
            <div class="shrink-0">
              <Icon
                name={service.icon}
                class={`w-12 h-12 ${i === services.length - 1 ? "text-brand-blue" : "text-brand-orange"}`}
              />
            </div>
            <div>
              <h2 class="font-heading text-2xl font-bold text-brand-blue mb-2">
                {service.title}
              </h2>
              <p class="text-gray-600 mb-4">{service.description}</p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-gray-700 mb-4">
                {service.bullets.map((bullet) => (
                  <li class="flex items-center gap-2">
                    <Icon
                      name="ph:check-bold"
                      class="w-4 h-4 text-brand-orange shrink-0 font-bold"
                    />
                    {bullet}
                  </li>
                ))}
              </ul>
              <a
                href={site.phone.href}
                class={`inline-flex items-center gap-2 text-white font-bold px-6 py-2 rounded-lg text-sm transition-colors ${i === services.length - 1 ? "bg-brand-blue hover:bg-brand-blue-dark" : "bg-brand-orange hover:bg-brand-orange-dark"}`}
              >
                <Icon name="ph:phone-call-bold" class="w-4 h-4 shrink-0" />
                {service.ctaLabel}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </main>

  <!-- CTA Banner -->
  <section class="bg-brand-orange py-12 px-4 text-center text-white">
    <h2 class="font-heading text-3xl font-extrabold mb-2">
      Ready to Get Your Garage Door Fixed?
    </h2>
    <p class="text-orange-100 mb-6 text-lg">
      Call us now for a free estimate — same-day service available.
    </p>
    <a
      href={site.phone.href}
      class="inline-flex items-center gap-3 bg-white text-brand-orange hover:bg-orange-50 font-bold px-10 py-4 rounded-xl text-xl transition-colors shadow-lg"
    >
      <Icon name="ph:phone-call-bold" class="w-6 h-6 shrink-0" />
      Call {site.phone.display}
    </a>
  </section>
</Layout>
